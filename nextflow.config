params {

    // Genomes, references, and other choices
    adapter_fa = "/projectnb/bf528/materials/project-3-chipseq/refs/TruSeq3-SE.fa"
    blacklist = "/projectnb/bf528/students/morzenti/ATACseq_cleaned/refs/mm10-blacklist.v2.bed" //dont need to do the liftover
    genome = "/projectnb/bf528/students/morzenti/ATACseq_cleaned/refs/GRCm39.primary_assembly.genome.fa"
    gtf = "/projectnb/bf528/students/morzenti/ATACseq_cleaned/refs/gencode.vM35.primary_assembly.annotation.gtf"
    TSS = "/projectnb/bf528/students/morzenti/ATACseq_cleaned/refs/mm39_TSS.bed"
    ucsc_genes = "/projectnb/bf528/students/morzenti/ATACseq_cleaned/refs/m39_genes.bed"
    window = 2000
    corrtype = 'spearman'

    // Download the data
    fileaccess = "$projectDir/csv_data/fileaccess.csv"

    // Created files from R analysis for matrix calculations
    cdc1_lost_peaks = "$projectDir/cDC1_lost_accessibility.bed"
    cdc1_gained_peaks = "$projectDir/cDC1_gained_accessibility.bed"
    cdc2_lost_peaks = "$projectDir/cDC2_lost_accessibility.bed"
    cdc2_gained_peaks = "$projectDir/cDC2_gained_accessibility.bed"

    // Directories
    outdir = "$projectDir/results/"
}


profiles {
    conda {
        conda.enabled = true
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    cluster {
        process {
                executor = 'sge'
                clusterOptions = '-P bf528'
                penv = 'omp'

                withLabel: process_single {
                    cpus = 1
                }

                withLabel: process_low {
                    cpus = 4

                }
                withLabel: process_medium {
                    cpus = 12
                    //8 at the lowest
                }
                
                withLabel: process_high {
                    cpus = 21
                }
        }
    }

    local {
        process.executor = 'local'
    }
}

executor {
    $sge {
        queueSize = 12
    }
    $local {
        cpus = 1
    }
}

resume = true